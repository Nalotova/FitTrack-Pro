{
  "entities": {
    "Workout": {
      "title": "Workout",
      "description": "A single workout session.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the user who performed the workout." },
        "date": { "type": "string", "format": "date-time", "description": "The date and time of the workout." },
        "name": { "type": "string", "description": "The name of the workout (e.g., 'Leg Day')." },
        "day": { "type": "string", "description": "The day of the program." },
        "isCardio": { "type": "boolean", "description": "Whether the entire workout is cardio-focused." },
        "notes": { "type": "string", "description": "Optional notes for the workout." },
        "exercises": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string", "description": "The name of the exercise." },
              "isCardio": { "type": "boolean", "description": "Whether this specific exercise is cardio." },
              "fields": { "type": "array", "items": { "type": "string" }, "description": "Custom field names for cardio (e.g., ['мин', 'пульс'])." },
              "sets": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "reps": { "type": "number", "description": "Number of repetitions." },
                    "weight": { "type": "number", "description": "Weight used in kg/lbs." },
                    "cardioValues": { "type": "array", "items": { "type": "number" }, "description": "Values for cardio fields." }
                  },
                  "required": ["reps", "weight"]
                }
              }
            },
            "required": ["name", "sets"]
          }
        }
      },
      "required": ["userId", "date", "exercises"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Basic user information.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string", "description": "The user's display name." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "photoURL": { "type": "string", "description": "The user's profile picture URL." },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "The user's role." },
        "gender": { "type": "string", "enum": ["male", "female"], "description": "The user's gender." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created." },
        "reminders": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "day": { "type": "string", "description": "Day of the week." },
              "time": { "type": "string", "description": "Time of the reminder." },
              "label": { "type": "string", "description": "Label for the reminder." }
            },
            "required": ["day", "time"]
          }
        }
      },
      "required": ["displayName", "email"]
    },
    "WeightMeasurement": {
      "title": "Weight Measurement",
      "description": "User's body weight and composition data including centimeter measurements.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "weight": { "type": "number" },
        "age": { "type": "number", "description": "User's age at the time of measurement." },
        "fat": { "type": "number" },
        "muscle": { "type": "number" },
        "water": { "type": "number" },
        "chest": { "type": "number", "description": "Chest measurement in cm." },
        "waist": { "type": "number", "description": "Waist measurement in cm." },
        "hips": { "type": "number", "description": "Hips measurement in cm." },
        "bicep": { "type": "number", "description": "Bicep measurement in cm." },
        "thigh": { "type": "number", "description": "Thigh measurement in cm." },
        "bmi": { "type": "number" },
        "visceralFat": { "type": "number" },
        "skeletalMuscleIndex": { "type": "number" },
        "waistHipRatio": { "type": "number" },
        "bodyType": { "type": "string" },
        "bodyShape": { "type": "string" },
        "bmr": { "type": "number" },
        "boneMass": { "type": "number" },
        "protein": { "type": "number" },
        "fatFreeMass": { "type": "number" },
        "biologicalAge": { "type": "number" },
        "heartRate": { "type": "number" }
      },
      "required": ["userId", "date", "weight"]
    },
    "StrengthRecord": {
      "title": "Strength Record",
      "description": "User's personal bests or working weights for specific exercises.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "exercise": { "type": "string" },
        "weight": { "type": "number" },
        "reps": { "type": "number" }
      },
      "required": ["userId", "date", "exercise", "weight", "reps"]
    },
    "CurrentWorkout": {
      "title": "Current Workout",
      "description": "The state of the user's current, active workout session.",
      "type": "object",
      "properties": {
        "currentDay": { "type": "string" },
        "checkedExercises": { "type": "array", "items": { "type": "number" } },
        "currentSets": { "type": "object" },
        "currentNotes": { "type": "object" }
      }
    },
    "TrainingProgram": {
      "title": "Training Program",
      "description": "The user's customized training program.",
      "type": "object",
      "properties": {
        "data": { "type": "object", "description": "The program structure (days and exercises)." },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["data", "updatedAt"]
    },
    "TechItem": {
      "title": "Tech Item",
      "description": "A technical tip or instruction for an exercise.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "content": { "type": "string", "description": "The multi-line text content of the tech tip." },
        "order": { "type": "number" }
      },
      "required": ["userId", "title", "subtitle", "content", "order"]
    },
    "CoachMessage": {
      "title": "Coach Message",
      "description": "A message in the coach chat history.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "assistant"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "role", "content", "timestamp"]
    }
  },
  "firestore": {
    "/workouts/{workoutId}": {
      "schema": "Workout",
      "description": "Collection of workout sessions."
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile information."
    },
    "/measurements/{measurementId}": {
      "schema": "WeightMeasurement",
      "description": "Body composition history."
    },
    "/strength/{recordId}": {
      "schema": "StrengthRecord",
      "description": "Exercise weight history."
    },
    "/current_workout/{userId}": {
      "schema": "CurrentWorkout",
      "description": "Active workout state."
    },
    "/programs/{userId}": {
      "schema": "TrainingProgram",
      "description": "User's custom training program."
    },
    "/tech/{techId}": {
      "schema": "TechItem",
      "description": "Collection of technical tips."
    },
    "/coach_messages/{messageId}": {
      "schema": "CoachMessage",
      "description": "Chat history with the AI coach."
    }
  }
}
